---
import MainVisual from "../components/top/MainVisual.astro";
import Layout from "../layouts/Layout.astro";
---

<style>
  .container {
    display: flex;
    max-width: 100%;
    height: 20em;

    align-items: center;
    justify-content: center;
  }

  .card {
    padding: 8px;

    background-color: #e6e6e6;
    border-radius: 4px;
  }

  .top-container {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
  }
</style>

<Layout title="Go Conference 2026">
  <main>
    <MainVisual />
  </main>
</Layout>
