---
import GlobalStyles from "../components/GlobalStyles.astro";
import Footer from "../components/Footer.astro";
import FooterVisual from "../assets/footer_visual.png";

interface Props {
  title?: string;
  showFooterVisual?: boolean;
}

const currentLocale = Astro.currentLocale;
const title = Astro.props.title ?? "Go Conference 2026";
---

<!doctype html>
<html lang={currentLocale}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="" />
    <link rel="icon" href="" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <GlobalStyles />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Barlow:ital,wght@0,100;0,200;0,300;0,400;0,500;0,600;0,700;0,800;0,900;1,100;1,200;1,300;1,400;1,500;1,600;1,700;1,800;1,900&family=Noto+Sans+JP:wght@100..900&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <div>
      <slot />
    </div>
    {
      Astro.props.showFooterVisual && (
        <img src={FooterVisual.src} alt="" class="footer-visual" />
      )
    }
    <Footer />
  </body>
</html>

<style>
  html,
  body {
    margin: 0;
    width: 100%;
    height: 100%;
  }

  .footer-visual {
    display: block;
    width: 100%;
    height: 300px;
    object-fit: cover;
    object-position: center;
  }

  @media (max-width: 1100px) {
    .footer-visual {
      height: auto;
      min-height: 81px;
    }
  }
</style>
