---
import GlobalStyles from "../components/GlobalStyles.astro";
import { constants } from "../constants";

import ogImageLg from "../../public/og_image_lg.jpg";
import ogImageMd from "../../public/og_image_md.jpg";
import favicon from "../../public/favicon.jpg";
import { withBaseURL } from "../utils/url";

const currentLocale = Astro.currentLocale;

interface Props {
  title?: string;
}

const { title = constants.pageTitle } = Astro.props as Props;
---

<!doctype html>
<html lang={currentLocale}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" href={withBaseURL("favicon.jpg")} />
    <meta name="generator" content={Astro.generator} />
    <title>Go Conference 2026</title>
    <GlobalStyles />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Barlow:ital,wght@0,100;0,200;0,300;0,400;0,500;0,600;0,700;0,800;0,900;1,100;1,200;1,300;1,400;1,500;1,600;1,700;1,800;1,900&family=Noto+Sans+JP:wght@100..900&display=swap"
      rel="stylesheet"
    />

    <!-- OGP の記載 -->
    <meta property="og:site_name" content={constants.pageTitle} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={Astro.url} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={constants.pageDescription} />
    <meta
      property="og:image"
      content={new URL(withBaseURL("og_image_lg.jpg"), Astro.url)}
    />

    <meta property="twitter:card" content="summary" />
    <meta property="twitter:url" content={Astro.url} />
    <meta property="twitter:title" content={title} />
    <meta property="twitter:description" content={constants.pageDescription} />
    <meta
      property="twitter:image"
      content={new URL(withBaseURL("og_image_md.jpg"), Astro.url)}
    />
  </head>
  <body>
    <slot />
  </body>
</html>

<style>
  html,
  body {
    margin: 0;
    width: 100%;
    height: 100%;
  }
</style>
