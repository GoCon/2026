---
import { staffs } from "./staff_list";
import XLogo from "../assets/icons/x.svg";
import GitHubLogo from "../assets/icons/github.svg";
---

<section class="staffs-section">
  <div class="staffs-title">
    <h2>みんなの「<span class="staffs-title-accent">Go コミュニティのここが好き！</span>」を<br />聞いてみました！</h2>
  </div>
  <div class="staffs-grid" data-staff-grid>
    {
      staffs.map((staff) => (
        <div class="staff-card">
          <div class="staff-top">
            <div
              class={`staff-avatar ${staff.avatar ? "staff-avatar--with-image" : "staff-avatar--placeholder"}`}
            >
              {staff.avatar && <img src={staff.avatar} alt={staff.name} />}
            </div>
            {staff.comment && (
              <div class="staff-comment-wrapper">
                <span class="staff-ha-mark" aria-hidden="true" />
                <p class="staff-comment">{staff.comment}</p>
              </div>
            )}
          </div>

          <div class="staff-footer">
            <div class="staff-text">
              <h3 class="staff-name">{staff.name}</h3>
              {staff.communities.length > 0 && (
                <div class="communities">
                  {staff.communities.map((community, index) => (
                    <span class="community-name">
                      {community}
                      {index < staff.communities.length - 1 && ", "}
                    </span>
                  ))}
                </div>
              )}
            </div>

            {staff.sns && staff.sns.url && (
              <a
                href={staff.sns.url}
                target="_blank"
                rel="noopener noreferrer"
                class="social-link"
                aria-label={`${staff.sns.type} Link`}
              >
                {staff.sns.type === "x" && <XLogo />}
                {staff.sns.type === "github" && <GitHubLogo />}
              </a>
            )}
          </div>
        </div>
      ))
    }
  </div>
</section>

<script>
  function shuffleStaffCards() {
    const grid = document.querySelector("[data-staff-grid]");
    if (!grid) return;

    const cards = Array.from(grid.children);
    for (let i = cards.length - 1; i > 0; i--) {
      const j = Math.floor(Math.random() * (i + 1));
      [cards[i], cards[j]] = [cards[j], cards[i]];
    }

    cards.forEach((card) => grid.appendChild(card));
    grid.classList.add("staffs-grid--ready");
  }

  shuffleStaffCards();
</script>

<noscript>
  <style>
    [data-staff-grid] {
      visibility: visible !important;
    }
  </style>
</noscript>

<style>
  .staffs-section {
    padding: 0;
  }

  .staffs-title {
    margin-bottom: 8px;
  }

  .staffs-title h2 {
    font-size: 24px;
    font-weight: 700;
    color: var(--text-primary);
    line-height: 1.6;
    margin: 0;
    padding-left: 30px;
    position: relative;
    word-break: keep-all;
    overflow-wrap: anywhere;
  }

  @media screen and (max-width: 768px) {
    .staffs-title h2 br {
      display: none;
    }
  }

  .staffs-title h2::before,
  .staffs-title h2::after {
    content: "";
    position: absolute;
    left: 2px;
    width: 18px;
    height: 1.5px;
    background: var(--text-primary);
    border-radius: 1px;
    transform-origin: left center;
  }

  /* 上線: / 方向 */
  .staffs-title h2::before {
    top: 14px;
    height: 1px;
    transform: rotate(-35deg);
  }

  /* 下線: \ 方向 */
  .staffs-title h2::after {
    bottom: 14px;
    height: 1px;
    transform: rotate(35deg);
  }

  .staffs-title-accent {
    color: var(--text-accent);
  }

  .staffs-grid {
    display: grid;
    gap: 24px;
    margin-top: 32px;
    justify-content: center;
    grid-template-columns: repeat(3, minmax(0, 360px));
    visibility: hidden;

    &.staffs-grid--ready {
      visibility: visible;
    }

    @media screen and (max-width: 1200px) {
      grid-template-columns: repeat(2, minmax(0, 360px));
    }

    @media screen and (max-width: 800px) {
      grid-template-columns: minmax(0, 360px);
    }
  }

  .staff-card {
    background: var(--primitive-light-blue);
    border-radius: 16px;
    padding: 20px;
    max-width: 360px;
    width: 100%;
    min-height: 160px;
    box-sizing: border-box;
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  /* 上段: アバター | (ハ字マーク + コメント) (横並び) */
  .staff-top {
    flex: 1;
    display: flex;
    flex-direction: row;
    align-items: center;
    gap: 10px;
  }

  /* ハ字マークとコメントを垂直中央揃えにするラッパー */
  .staff-comment-wrapper {
    display: flex;
    flex-direction: row;
    align-items: center;
    gap: 8px;
    flex: 1;
  }

  .staff-avatar {
    width: 72px;
    height: 72px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .staff-avatar--with-image {
    background: #fff;
  }

  .staff-avatar--placeholder {
    background: #c4c4c4;
  }

  .staff-avatar img {
    width: 100%;
    height: 100%;
    border-radius: 50%;
    object-fit: cover;
  }

  /* ハを横に回転させた2本の斜線 (黒) */
  .staff-ha-mark {
    width: 14px;
    height: 60px;
    position: relative;
    flex-shrink: 0;
  }

  .staff-ha-mark::before,
  .staff-ha-mark::after {
    content: "";
    position: absolute;
    left: 0;
    width: 16px;
    height: 1px;
    background: var(--text-primary);
    border-radius: 1px;
    transform-origin: left center;
  }

  /* 上線: / 方向 */
  .staff-ha-mark::before {
    top: 6px;
    transform: rotate(-35deg);
  }

  /* 下線: \ 方向 — 2本の中点が height の中央(14px)と一致 */
  .staff-ha-mark::after {
    bottom: 6px;
    transform: rotate(35deg);
  }

  .staff-comment {
    flex: 1;
    font-size: 13px;
    color: var(--text-accent, #00c1e5);
    margin: 0;
    line-height: 1.6;
    font-weight: 600;
  }

  /* 下段: 名前・組織名 (左) | SNS アイコン (右) */
  .staff-footer {
    display: flex;
    align-items: end;
    justify-content: space-between;
  }

  .staff-text {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .staff-name {
    font-size: 18px;
    font-weight: 700;
    color: var(--text-primary);
    margin: 0;
    line-height: 1.2;
  }

  .communities {
    display: flex;
    align-items: center;
    gap: 4px;
    margin: 0;
    flex-wrap: wrap;
  }

  .community-name {
    font-size: 12px;
    font-weight: 700;
    color: var(--text-secondary);
  }

  .social-link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    text-decoration: none;
    border-radius: 4px;
    transition: opacity 0.2s ease;
    flex-shrink: 0;

    &:hover {
      opacity: 0.7;
    }
  }

  .social-link svg {
    width: 32px;
    height: 32px;
    fill: var(--text-primary);
  }
</style>
