---
import { Image } from "astro:assets";
import Gopher from "../assets/page-header-gopher.png";

/** 最大幅の指定がないレイアウト（トップページや凝ったページ作成時に利用してください） */

interface Props {
  /** ページタイトル（日本語部分） */
  title?: string;
  /** ページタイトル（英語部分） */
  titleEn?: string;
}

const { title, titleEn } = Astro.props;
const currentLocale = Astro.currentLocale || "ja";
---

<style>
  .article {
    flex: 1;
  }

  .page-header {
    background: var(--gradient);

    & .inner {
      position: relative;
      max-width: 1200px;
      width: 100%;
      margin: 0 auto;
      padding: 40px 40px;
      box-sizing: border-box;

      @media screen and (max-width: 860px) {
        & {
          padding: 24px 24px;
        }
      }
    }

    & .gopher {
      position: absolute;
      bottom: -110px;
      right: 0;
      z-index: 1;

      @media screen and (max-width: 860px) {
        & {
          bottom: -56px;
          right: 8px;
          width: 140px;
          height: auto;
        }
      }
    }
  }

  .page-title {
    display: flex;
    flex-direction: column;
    margin: 0;
    padding-right: 200px;
    box-sizing: border-box;
    font-weight: 700;
    color: var(--text-on-fill);
    overflow-wrap: break-word;

    @media screen and (max-width: 860px) {
      & {
        padding-right: 80px;
      }
    }

    & .jp {
      font-size: 24px;
      line-height: 1.5;

      @media screen and (max-width: 860px) {
        & {
          font-size: 18px;
        }
      }
    }

    & .en {
      font-family: "Barlow", sans-serif;
      font-size: 68px;
      line-height: 1.5;

      @media screen and (max-width: 860px) {
        & {
          font-size: 40px;
        }
      }
    }
  }

  .main {
    position: relative;
    background: var(--surface-primary);
    border-radius: 80px 80px 0 0;

    @media screen and (max-width: 860px) {
      & {
        border-radius: 20px 20px 0 0;
      }
    }

    &:before {
      content: "";
      position: absolute;
      top: 0;
      left: 0;
      right: 0;
      height: 80px;
      background: var(--gradient);
      z-index: -1;
    }

    & .inner {
      max-width: 1200px;
      width: 100%;
      margin: 0 auto;
      padding: 80px 40px;
      box-sizing: border-box;

      @media screen and (max-width: 860px) {
        & {
          padding: 40px 20px;
        }
      }
    }
  }
</style>

<article class="article">
  <div class="page-header">
    <div class="inner">
      <h1 class="page-title">
        <span class="jp" aria-hidden={currentLocale === "en"}>
          {title}
        </span>
        <span class="en" aria-hidden={currentLocale === "ja"}>
          {titleEn}
        </span>
      </h1>
      <Image
        src={Gopher}
        alt="Gopher"
        class="gopher"
        width={275}
        height={275}
        priority
      />
    </div>
  </div>
  <main class="main">
    <div class="inner">
      <slot />
    </div>
  </main>
</article>
