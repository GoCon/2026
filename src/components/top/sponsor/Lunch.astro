---
import { Image } from "astro:assets";
import type { SponsorWithDialog } from "../sponsors";
import Dialog from "./Dialog.astro";

interface Props {
  sponsors: SponsorWithDialog[];
}

const { sponsors } = Astro.props;

if (sponsors.length === 0) {
  return null;
}

const currentLocale = Astro.currentLocale || "ja";
---

<div class="sponsor-section">
  <h4 class="text-h4">
    {currentLocale === "ja" ? "ランチ" : "Lunch"}
  </h4>
  <ul>
    {
      sponsors.map((sponsor) => (
        <li>
          <Image
            src={sponsor.imageSrc}
            alt={sponsor.name}
            title={sponsor.name}
            width={354}
            height={164}
            loading="lazy"
            priority
            onclick={`document.getElementById('${sponsor.dialog.openId}')?.showModal()`}
          />
          <Dialog
            sponsorSectionTitle={
              currentLocale === "ja" ? "ランチスポンサー" : "Lunch Sponsor"
            }
            sponsor={sponsor}
          />
        </li>
      ))
    }
  </ul>
</div>

<style>
  .sponsor-section {
    text-align: center;
  }

  ul {
    display: grid;
    grid-template-columns: repeat(3, auto);
    list-style: none;
    text-align: center;
    padding: 0;
    gap: 20px;
    margin: 0 auto;
    width: fit-content;
    max-width: 100%;
  }

  li {
    max-width: 100%;
  }

  img {
    cursor: pointer;
    object-fit: contain;
  }

  img:hover {
    opacity: 0.7;
  }

  @media screen and (max-width: 1150px) {
    ul {
      grid-template-columns: repeat(2, auto);
    }
  }

  @media screen and (max-width: 768px) {
    ul {
      grid-template-columns: repeat(1, auto);
      gap: 24px;
    }

    ul img {
      width: 262px;
      height: 64px;
    }
  }
</style>
