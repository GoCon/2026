---
import { jobBoards } from "./jobBoards";
---

<section id="job-board">
  <div class="container">
    {
      jobBoards.map((jobBoard) => (
        <a
          href={jobBoard.url}
          class="job-board-item"
          target="_blank"
          rel="noopener noreferrer"
        >
          <img
            class="job-board-image"
            src={jobBoard.image.src}
            alt={jobBoard.description}
          />
        </a>
      ))
    }
  </div>
</section>

<style>
  .container {
    display: flex;
    flex-wrap: wrap;
    gap: 24px;
    box-sizing: border-box;
  }

  .job-board-item {
    flex: 0 0 calc((100% - 28px) / 2);
    box-sizing: content-box;
    border: 1px solid var(--surface-disabled);
    aspect-ratio: 2/1;
    width: 100%;
    height: 100%;
  }

  .job-board-image {
    width: 100%;
    height: 100%;
    object-fit: contain;
    display: block;
  }

  @media screen and (max-width: 768px) {
    .container {
      flex-direction: column;
    }

    .job-board-item {
      flex: none;
    }
  }
</style>
