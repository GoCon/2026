---
type Props = {
  text: string;
};

const { text } = Astro.props as Props;
---

<div class="chip">
  <h4 class="text-h4">{text}</h4>
</div>

<style>
  .chip {
    background-color: var(--surface-secondary-dark);
    color: var(--text-on-fill);
    padding: var(--space-xxs) var(--space-s);
    border-radius: var(--radius-objects);
    width: 100%;
    min-width: 160px;
    box-sizing: border-box;
    text-align: center;
  }

  h4 {
    margin: 0 auto;
  }

  @media screen and (max-width: 768px) {
    .chip {
      padding: var(--space-xxxs) var(--space-s);
    }
  }
</style>
