---
import { getRelativeLocaleUrl } from "astro:i18n";
import CloseIcon from "../assets/icons/close.svg";
import MenuIcon from "../assets/icons/menu.svg";
import Logo from "../assets/mainVisual/mv_logo_sp.svg";
import { getLocaleUrlForPage } from "../utils/i18n";
import TextLink from "./ui/TextLink.astro";
import Button from "./ui/Button.astro";

const currentLocale = Astro.currentLocale || "ja";
const pathname = Astro.url.pathname;
---

<style>
  .header {
    position: fixed;
    width: 100%;
    top: 0;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 4px 40px;
    height: 81px;
    box-sizing: border-box;
    background: var(--surface-primary);
    z-index: 1000;
  }

  .header-logo {
    display: block;
    height: 100%;
    width: 165px;
    padding: 8px;
    box-sizing: border-box;
    margin: 0;
    flex-shrink: 0;
  }

  .header-logo a {
    display: flex;
    width: 100%;
    height: 100%;
  }

  .header-logo img {
    width: 100%;
    height: auto;
    object-fit: contain;
  }

  .header-button {
    width: 192px;
  }

  .language-switcher {
    display: flex;
    gap: var(--space-xxxs);
  }

  .language-switcher .active {
    text-decoration: underline;
  }

  .language-switcher a {
    text-decoration: none;
    color: var(--text-primary);
  }

  .language-switcher a:hover {
    color: var(--text-accent);
  }

  @media screen and (max-width: 768px) {
    .header {
      padding: 4px 24px;
      height: 56px;
    }

    .header-logo {
      width: 103px;
    }
  }

  .navigation {
    display: flex;
    align-items: center;
    gap: 26px;

    & .navigation-menu {
      display: flex;
      gap: 26px;
      list-style: none;
      margin: 0;
      padding: 0;
    }

    @media screen and (max-width: 768px) {
      & {
        position: fixed;
        top: 56px;
        left: 0;
        right: 0;
        bottom: 0;
        display: none;
        flex-direction: column;
        justify-content: center;
        align-items: flex-start;
        padding: 40px 32px 73px;
        gap: 40px;
        background: rgba(255, 255, 255, 0.8);
        backdrop-filter: blur(32px);
        z-index: 1000;

        & .navigation-menu {
          flex-direction: column;
          padding: 0 16px;
          gap: 32px;
        }
      }
    }
  }

  .navigation-toggle {
    display: none;
  }

  .navigation-icon {
    display: none;
    justify-content: center;
    align-items: center;
    width: 48px;
    height: 48px;
    background: var(--surface-secondary-dark);
    border-radius: 100%;
    cursor: pointer;

    @media screen and (max-width: 768px) {
      & {
        display: inline-flex;
      }
    }

    & .menu-icon {
      fill: var(--text-on-fill);
    }

    & .close-icon {
      display: none;
      fill: var(--text-on-fill);
    }
  }

  @media screen and (max-width: 768px) {
    .navigation-icon {
      width: 40px;
      height: 40px;
    }

    .navigation-menu-item {
      width: fit-content;
    }
  }

  .navigation-toggle:checked {
    & ~ * .menu-icon {
      display: none;
    }
    & ~ * .close-icon {
      display: inline;
    }
    & ~ .navigation {
      display: flex;
      gap: 80px;
    }
  }
</style>

<header class="header">
  <h1 class="header-logo">
    <a href={getRelativeLocaleUrl(currentLocale)}>
      <img src={Logo.src} alt={"Go Conference 2026"} />
    </a>
  </h1>
  <input type="checkbox" id="navigation-toggle" class="navigation-toggle" />
  <label for="navigation-toggle" class="navigation-icon">
    <MenuIcon class="menu-icon" />
    <CloseIcon class="close-icon" />
  </label>
  <div class="navigation">
    <ul class="navigation-menu">
      <li class="navigation-menu-item">
        <TextLink href={getRelativeLocaleUrl(currentLocale)} text="Home" />
      </li>
      <li>
        <TextLink
          href={getRelativeLocaleUrl(currentLocale, "staffs")}
          text="Staffs"
        />
      </li>
      <li class="navigation-menu-item">
        <TextLink
          href="https://docs.google.com/document/d/1jZqZfcH7NqCMyPXt_ZhvhlFXj4fKF-TNfXG_GIHBsfo/edit?tab=t.0#heading=h.95wf1aolrg0m"
          text="Sponsor FAQ"
          isBlankLink
        />
      </li>
      <!-- <li>
        <a href={getRelativeLocaleUrl(currentLocale, "timetable")}>
          Timetable
        </a>
      </li>
      <li>
        <a href={getRelativeLocaleUrl(currentLocale, "jobboard")}>
          Job Board
        </a>
      </li>
      <li>
        <a href={getRelativeLocaleUrl(currentLocale, "floormap")}>
          Floor Map
        </a>
      </li> -->

      <!-- 言語切り替えボタン -->
      <li class="language-switcher">
        {
          currentLocale === "ja" ? (
            <span class="active text-body-large-strong">JP</span>
          ) : (
            <a href={getLocaleUrlForPage("ja", pathname)}>JP</a>
          )
        }
        <div>/</div>
        {
          currentLocale === "en" ? (
            <span class="active text-body-large-strong">EN</span>
          ) : (
            <a href={getLocaleUrlForPage("en", pathname)}>EN</a>
          )
        }
      </li>
    </ul>

    <!-- メインボタン -->
    <!-- <div class="header-button">
      <Button href="#" isBlankLink>
        {
          currentLocale === "ja"
            ? "プロポーザルに応募"
            : "Apply for the proposal"
        }
      </Button>
    </div> -->
  </div>
</header>
